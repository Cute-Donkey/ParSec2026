{
    "name": "ParSec Nova",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/github-cli:1": {},
        "ghcr.io/devcontainers/features/dotnet:1": {},
        "ghcr.io/devcontainers/features/go:1": {}
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-dotnettools.csharp",
                "godotengine.godot-tools",
                "ms-vscode.hexeditor",
                "redhat.vscode-yaml",
                "ms-vscode.cpptools"
            ]
        }
    }
}
